---
import Layout from '../layouts/Layout.astro'
import {
  Mail,
  Phone,
  MapPin,
  Linkedin,
  GraduationCap,
  Briefcase,
  Award,
} from 'lucide-astro'

const skills = [
  'Logística Multimodal',
  'Gestión de Transporte',
  'Derecho Mercantil',
  'Ciencias Políticas',
  'Planificación Estratégica',
  'Análisis de Datos',
]
---

<Layout title="Curriculum Vitae | Yeisury Coronel Saldaña">
  <div
    class="max-w-4xl mx-auto bg-white p-10 md:p-16 shadow-none md:shadow-2xl my-0 md:my-10 print:my-0 print:p-0 print:shadow-none"
  >
    <!-- Header Section -->
    <div
      class="flex flex-col md:flex-row print:flex-row justify-between items-start border-b-2 border-slate-900 pb-8 mb-10 gap-6"
    >
      <div
        class="flex flex-col md:flex-row print:flex-row items-center md:items-start print:items-start gap-6"
      >
        <!-- Photo - Minimalist for CV -->
        <div
          class="w-24 h-24 md:w-32 md:h-32 bg-slate-100 rounded-full overflow-hidden border-2 border-slate-200 shrink-0"
        >
          <img
            src="/perfil.png"
            alt="Yeisury Coronel Saldaña"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="text-center md:text-left print:text-left">
          <h1
            class="text-4xl font-serif font-bold text-slate-900 mb-2 uppercase tracking-tight"
          >
            Yeisury Coronel Saldaña
          </h1>
          <p
            class="text-xl font-medium text-slate-600 uppercase tracking-widest"
          >
            Logística & Derecho
          </p>
        </div>
      </div>
      <div
        class="mt-4 md:mt-0 print:mt-0 text-center md:text-right print:text-right text-sm space-y-1 text-slate-700 w-full md:w-auto print:w-auto"
      >
        <div
          class="flex items-center justify-center md:justify-end print:justify-end space-x-2 group/cv-mail"
        >
          <a
            href="mailto:coronelyeisury5@gmail.com"
            class="hover:text-accent transition-colors"
          >
            <span>coronelyeisury5@gmail.com</span>
          </a>
          <button
            onclick="copyToClipboard('coronelyeisury5@gmail.com')"
            class="p-1 text-slate-400 hover:text-accent transition-colors print:hidden"
            title="Copiar correo"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="lucide lucide-copy"
              ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"
              ></rect><path
                d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
              ></path></svg
            >
          </button>
          <Mail size={14} class="text-slate-400" />
        </div>
        <a
          href="tel:+50763580722"
          class="flex items-center justify-center md:justify-end print:justify-end space-x-2 hover:text-accent transition-colors"
        >
          <span>+507 6358-0722</span>
          <Phone size={14} class="text-slate-400" />
        </a>
        <div
          class="flex items-center justify-center md:justify-end print:justify-end space-x-2 text-slate-700"
        >
          <span>Panamá</span>
          <MapPin size={14} class="text-slate-400" />
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 print:grid-cols-3 gap-10">
      <!-- Sidebar / Left Column -->
      <div class="md:col-span-1 print:col-span-1 space-y-10">
        <section>
          <h2
            class="text-xs font-bold text-slate-900 uppercase tracking-widest border-b border-slate-200 pb-2 mb-4"
          >
            Perfil
          </h2>
          <p class="text-sm text-slate-600 leading-relaxed">
            Estudiante con formación en Logística y Derecho, interesada en unir
            la operatividad logística con el marco legal. Comprometida con el
            aprendizaje continuo y el desarrollo de soluciones integrales para
            el comercio.
          </p>
        </section>

        <section>
          <h2
            class="text-xs font-bold text-slate-900 uppercase tracking-widest border-b border-slate-200 pb-2 mb-4"
          >
            Competencias
          </h2>
          <ul class="space-y-2">
            {
              skills.map((skill) => (
                <li class="text-sm text-slate-700 flex items-center space-x-2">
                  <span class="w-1.5 h-1.5 bg-slate-400 rounded-full" />
                  <span>{skill}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section>
          <h2
            class="text-xs font-bold text-slate-900 uppercase tracking-widest border-b border-slate-200 pb-2 mb-4"
          >
            Idiomas
          </h2>
          <div class="space-y-4">
            <div>
              <p class="text-sm font-bold text-slate-800">Español</p>
              <p class="text-xs text-slate-500 uppercase tracking-wider">
                Nativo
              </p>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-800">Inglés</p>
              <p class="text-xs text-slate-500 uppercase tracking-wider">
                Comprensión Técnica
              </p>
            </div>
          </div>
        </section>
      </div>

      <!-- Main / Right Column -->
      <div class="md:col-span-2 print:col-span-2 space-y-10">
        <section>
          <div class="flex items-center space-x-2 mb-6">
            <GraduationCap size={20} class="text-slate-900" />
            <h2
              class="text-xs font-bold text-slate-900 uppercase tracking-widest"
            >
              Educación
            </h2>
          </div>
          <div class="space-y-6">
            <div>
              <div class="flex justify-between items-baseline mb-1">
                <h3 class="text-base font-bold text-slate-900">
                  Lic. en Logística y Transporte Multimodal
                </h3>
                <span class="text-xs font-bold text-slate-500"
                  >2022 - Presente</span
                >
              </div>
              <p class="text-sm text-slate-700 italic">
                Universidad Tecnológica de Panamá (UTP)
              </p>
            </div>
            <div>
              <div class="flex justify-between items-baseline mb-1">
                <h3 class="text-base font-bold text-slate-900">
                  Lic. en Derecho y Ciencias Políticas
                </h3>
                <span class="text-xs font-bold text-slate-500"
                  >2021 - Presente</span
                >
              </div>
              <p class="text-sm text-slate-700 italic">
                Universidad Autónoma de Chiriquí (UNACHI)
              </p>
            </div>
            <div>
              <div class="flex justify-between items-baseline mb-1">
                <h3 class="text-base font-bold text-slate-900">
                  Bachiller en Humanidades
                </h3>
                <span class="text-xs font-bold text-slate-500">2021</span>
              </div>
              <p class="text-sm text-slate-700 italic">
                Graduada con Excelencia
              </p>
            </div>
          </div>
        </section>

        <section>
          <div class="flex items-center space-x-2 mb-6">
            <Briefcase size={20} class="text-slate-900" />
            <h2
              class="text-xs font-bold text-slate-900 uppercase tracking-widest"
            >
              Objetivo Profesional
            </h2>
          </div>
          <p class="text-sm text-slate-600 leading-relaxed">
            Contribuir al fortalecimiento de los sectores logístico y legal,
            aplicando una visión técnica y regulatoria para optimizar procesos
            en instituciones de relevancia nacional e internacional.
          </p>
        </section>

        <section>
          <div class="flex items-center space-x-2 mb-6">
            <Award size={20} class="text-slate-900" />
            <h2
              class="text-xs font-bold text-slate-900 uppercase tracking-widest"
            >
              Logros
            </h2>
          </div>
          <p
            class="text-sm text-slate-600 leading-relaxed italic border-l-2 border-slate-200 pl-4"
          >
            Comprometida con la excelencia académica y la formación continua,
            participando en foros de derecho y actualización logística.
          </p>
        </section>
      </div>
    </div>

    <!-- Action Button (Hidden on Print) -->
    <div class="mt-16 text-center print:hidden border-t pt-10">
      <button
        onclick="window.print()"
        class="bg-slate-900 text-white px-8 py-3 rounded-full font-bold hover:bg-slate-800 transition-all flex items-center space-x-2 mx-auto shadow-xl"
      >
        <span>Imprimir o Guardar como PDF</span>
      </button>
      <p class="text-xs text-slate-400 mt-4">
        Nota: Para mejores resultados, habilita "Gráficos de fondo" en la
        configuración de impresión.
      </p>
    </div>
  </div>

  <script>
    // Automáticamente abrir el diálogo de impresión si se llega con un parámetro
    if (window.location.search.includes('print')) {
      window.print()
    }
  </script>
</Layout>
