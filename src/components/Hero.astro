---
import { Linkedin, Mail, MapPin, Phone } from 'lucide-astro'
---

<section id="inicio" class="relative pt-32 pb-20 overflow-hidden bg-slate-50">
  <!-- Decorative background elements -->
  <div
    class="absolute top-0 right-0 -translate-y-12 translate-x-12 w-96 h-96 bg-accent/5 rounded-full blur-3xl"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 translate-y-12 -translate-x-12 w-64 h-64 bg-slate-200/50 rounded-full blur-2xl"
  >
  </div>

  <div class="container mx-auto px-6 relative">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <!-- Image Wrapper -->
      <div class="w-full lg:w-1/2 flex justify-center">
        <div class="relative group">
          <!-- Decorative Frame -->
          <div
            class="absolute -inset-4 border border-accent/20 rounded-2xl -rotate-3 transition-transform group-hover:rotate-0 duration-500"
          >
          </div>
          <div
            class="absolute -inset-4 border border-primary/10 rounded-2xl rotate-3 transition-transform group-hover:rotate-0 duration-500"
          >
          </div>

          <!-- Photo Placeholder -->
          <div
            class="relative w-64 h-80 sm:w-80 sm:h-112.5 bg-slate-200 rounded-xl overflow-hidden shadow-2xl flex items-center justify-center border-4 border-white"
          >
            <span class="text-slate-400 font-serif italic">Yeisury Coronel</span
            >
            <!-- Imagen real iría aquí: <img src="/tu-foto.jpg" alt="Yeisury Coronel" class="w-full h-full object-cover" /> -->
          </div>
        </div>
      </div>

      <!-- Text Content -->
      <div class="w-full lg:w-1/2 text-center lg:text-left">
        <div
          class="inline-flex items-center space-x-2 bg-accent/10 text-accent px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-6"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"
            ></span>
          </span>
          <span>Logística & Derecho</span>
        </div>

        <h1
          class="text-5xl lg:text-7xl font-serif font-bold text-primary mb-4 leading-tight"
        >
          Yeisury <span class="block italic text-accent font-normal"
            >Coronel Saldaña</span
          >
        </h1>

        <p
          class="text-xl text-secondary mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed"
        >
          Estudiante de Logística y Transporte Multimodal en la UTP y de Derecho
          y Ciencias Políticas en la Unachi. Enfocada en la eficiencia operativa
          y el marco legal del comercio global.
        </p>

        <div class="flex flex-wrap justify-center lg:justify-start gap-4 mb-10">
          <div
            class="flex items-center bg-white border border-slate-200 rounded-lg shadow-sm hover:bg-slate-50 transition-all group/email-hero overflow-hidden"
          >
            <a
              href="mailto:coronelyeisury5@gmail.com"
              class="flex items-center space-x-2 text-primary px-6 py-3"
            >
              <Mail size={18} class="text-accent" />
              <span class="font-medium whitespace-nowrap"
                >coronelyeisury5@gmail.com</span
              >
            </a>
            <button
              onclick="copyToClipboard('coronelyeisury5@gmail.com')"
              class="p-3 border-l border-slate-100 text-accent hover:bg-accent hover:text-white transition-colors"
              title="Copiar correo"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-copy"
                ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"
                ></rect><path
                  d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                ></path></svg
              >
            </button>
          </div>
          <a
            href="https://www.linkedin.com/in/yeisury-coronel-44851b355"
            target="_blank"
            class="flex items-center space-x-2 bg-white border border-slate-200 text-primary px-6 py-3 rounded-lg hover:bg-slate-50 transition-all shadow-sm"
          >
            <Linkedin size={18} class="text-accent" />
            <span class="font-medium">LinkedIn</span>
          </a>
        </div>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm text-secondary border-t border-slate-200 pt-8 max-w-lg mx-auto lg:mx-0"
        >
          <a
            href="tel:+50763580722"
            class="flex items-center space-x-3 hover:text-primary transition-colors group/tel"
          >
            <div
              class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center group-hover/tel:bg-accent group-hover/tel:text-white transition-all"
            >
              <Phone size={16} />
            </div>
            <div>
              <p class="font-semibold text-primary">Teléfono</p>
              <p>+507 6358-0722</p>
            </div>
          </a>
          <div class="flex items-center space-x-3">
            <div
              class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center"
            >
              <MapPin size={16} class="text-primary" />
            </div>
            <div>
              <p class="font-semibold text-primary">Ubicación</p>
              <p>Panamá</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
