---
import { Download, Linkedin, Mail } from 'lucide-astro'

const navItems = [
  { name: 'Inicio', href: '#inicio' },
  { name: 'Sobre Mí', href: '#sobre-mi' },
  { name: 'Educación', href: '#educacion' },
  { name: 'Contacto', href: '#contacto' },
]
---

<header class="fixed top-0 left-0 right-0 z-50 glass no-print">
  <div class="container mx-auto px-6 py-4 flex justify-between items-center">
    <a
      href="#inicio"
      class="text-2xl font-serif font-bold tracking-tight text-primary"
    >
      YC<span class="text-accent">.</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex space-x-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-secondary hover:text-primary transition-colors"
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center space-x-4">
      <a
        href="/cv"
        class="hidden sm:flex items-center space-x-2 bg-primary text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-slate-800 transition-all shadow-lg hover:shadow-xl active:scale-95"
      >
        <Download size={16} />
        <span>Descargar CV</span>
      </a>
      <button
        id="menu-btn"
        class="md:hidden text-primary p-2 focus:outline-none"
        aria-label="Abrir menú"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-menu"
          ><line x1="4" x2="20" y1="12" y2="12"></line><line
            x1="4"
            x2="20"
            y1="6"
            y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg
        >
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Backdrop -->
<div
  id="menu-backdrop"
  class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-90 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
>
</div>

<!-- Mobile Side Drawer -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 bottom-0 w-80 bg-white z-100 shadow-2xl transform translate-x-full transition-transform duration-500 ease-in-out md:hidden flex flex-col border-l border-slate-100"
>
  <div
    class="p-6 flex justify-between items-center border-b border-slate-100 bg-white"
  >
    <span class="text-xl font-serif font-bold text-primary italic"
      >YC<span class="text-accent">.</span></span
    >
    <button
      id="close-btn"
      class="p-3 text-slate-400 hover:text-primary transition-colors hover:bg-slate-100 rounded-xl"
      aria-label="Cerrar menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-x"
        ><line x1="18" x2="6" y1="6" y2="18"></line><line
          x1="6"
          x2="18"
          y1="6"
          y2="18"></line></svg
      >
    </button>
  </div>

  <nav
    class="flex-1 px-8 py-10 flex flex-col space-y-6 overflow-y-auto bg-white"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="mobile-link text-2xl font-serif font-bold text-slate-400 hover:text-primary transition-all border-l-4 border-transparent hover:border-accent pl-4"
        >
          {item.name}
        </a>
      ))
    }
  </nav>

  <div class="p-8 space-y-8 border-t border-slate-100 bg-slate-50">
    <a
      href="/cv"
      class="flex items-center justify-center space-x-3 bg-primary text-white w-full py-4 rounded-2xl font-bold shadow-xl active:scale-95 transition-all text-lg"
    >
      <Download size={20} />
      <span>Descargar CV</span>
    </a>

    <div class="flex flex-col space-y-4">
      <p
        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] text-center"
      >
        Canales de Contacto
      </p>
      <div class="flex justify-center space-x-6">
        <a
          href="https://wa.me/50763580722"
          class="w-14 h-14 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center hover:bg-emerald-600 hover:text-white transition-all shadow-sm border border-emerald-100"
          aria-label="WhatsApp"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-message-circle"
            ><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path></svg
          >
        </a>
        <button
          onclick="copyToClipboard('coronelyeisury5@gmail.com'); closeMenu()"
          class="w-14 h-14 bg-accent/5 text-accent rounded-2xl flex items-center justify-center hover:bg-accent hover:text-white transition-all shadow-sm border border-accent/20"
          aria-label="Copiar correo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-copy"
            ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path
              d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
            ></path></svg
          >
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById('menu-btn')
  const closeBtn = document.getElementById('close-btn')
  const mobileMenu = document.getElementById('mobile-menu')
  const menuBackdrop = document.getElementById('menu-backdrop')
  const mobileLinks = document.querySelectorAll('.mobile-link')

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full')
    menuBackdrop?.classList.remove('opacity-0', 'pointer-events-none')
    document.body.style.overflow = 'hidden'
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full')
    menuBackdrop?.classList.add('opacity-0', 'pointer-events-none')
    document.body.style.overflow = ''
  }

  menuBtn?.addEventListener('click', openMenu)
  closeBtn?.addEventListener('click', closeMenu)
  menuBackdrop?.addEventListener('click', closeMenu)

  mobileLinks.forEach((link) => {
    link.addEventListener('click', closeMenu)
  })
</script>
