---
interface Props {
  id: string
  title: string
  subtitle?: string
  className?: string
}

const { id, title, subtitle, className = '' } = Astro.props
---

<section id={id} class={`py-20 ${className}`}>
  <div class="container mx-auto px-6">
    <div class="mb-12 text-center">
      <h2 class="text-4xl font-serif font-bold text-primary mb-4">{title}</h2>
      {
        subtitle && (
          <p class="text-lg text-secondary max-w-2xl mx-auto leading-relaxed">
            {subtitle}
          </p>
        )
      }
      <div class="w-20 h-1 bg-accent mx-auto mt-6 rounded-full"></div>
    </div>
    <slot />
  </div>
</section>
